---
import HeaderLink from "./HeaderLink.astro";
import { title, subtitle } from "../settings/settings.json"

---

<header>
	<div class="header-section">
		<div class="header-frame">
			<div class="header-text">
				<h1>{title}</h1>
				<h2>{subtitle}</h2>
			</div>
			<img src="/gagan-deep-singh.jpg" alt="Gagan Deep Singh" class="profile-image" />
		</div>
	</div>
</header>
<nav>
	<HeaderLink href="/">home</HeaderLink>
	<HeaderLink href="/posts">posts</HeaderLink>
	<HeaderLink href="/about">about</HeaderLink>
</nav>
<style>
	.header-section {
		display: flex;
		justify-content: center;
	}
	.header-frame {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 2rem;
		width: 100%;
		max-width: 70ch;
	}
	.profile-image {
		width: 100px;
		height: 100px;
		border-radius: 50%;
		object-fit: cover;
		flex-shrink: 0;
	}
	@media (max-width: 600px) {
		.profile-image {
			display: none;
		}
	}
	.header-text {
		flex: 1;
	}
	.header-text h1 {
		margin: 0;
	}
	.header-text h2 {
		margin: 0.5em 0 0 0;
	}
</style>
