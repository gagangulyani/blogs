---
import HeaderLink from "./HeaderLink.astro";
import { title, subtitle } from "../settings/settings.json"

---

<header>
	<div class="header-section">
		<div class="header-frame">
			<img src="/gagan-deep-singh.jpg" alt="Gagan Deep Singh" class="profile-image" />
			<div class="header-text">
				<h1>{title}</h1>
				<h2>{subtitle}</h2>
			</div>
		</div>
	</div>
</header>
<nav>
	<HeaderLink href="/">home</HeaderLink>
	<HeaderLink href="/posts">posts</HeaderLink>
	<HeaderLink href="/about">about</HeaderLink>
</nav>
<style>
	.header-frame {
		display: flex;
		align-items: center;
		gap: 2rem;
		flex-wrap: wrap;
	}
	.profile-image {
		width: 120px;
		height: 120px;
		border-radius: 50%;
		object-fit: cover;
	}
	.header-text h1,
	.header-text h2 {
		margin: 0;
		text-align: left;
	}
	.header-text h2 {
		margin-top: 0.5em;
	}
</style>
